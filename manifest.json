{
    "name": "Dynamic Prompts",
    "description": "Generate prompts from dynamic templates and insert them into AI tools.",
    "version": "1.0",
    "manifest_version": 3,
    "action": {
        "default_icon": "icon.png",
        "default_title": "Dynamic Prompts"
    },
    "background": {
        "service_worker": "background.js"
    },
    "side_panel": {
        "default_path": "sidepanel.html"
    },
    "content_scripts": [
        {
            "js": ["content.js"],
            "matches": ["https://grok.com/imagine*"]
        }
    ],
    "permissions": ["sidePanel", "tabs", "activeTab"],
    "host_permissions": ["https://grok.com/*"]
}
